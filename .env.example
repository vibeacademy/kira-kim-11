# Local development environment variables.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# These three variables are everything app/config.py reads at runtime.
# All other secrets (Neon API key, GCP credentials, etc.) live in GitHub
# Actions secrets/variables, not in .env — see docs/SECRETS.md for the
# full inventory and where each value is stored.

# Database connection string read by SQLAlchemy.
#   - Local dev:  sqlite:///./dev.db   (the default if unset)
#   - Neon dev:   postgresql://neondb_owner:<pwd>@ep-xxx-pooler.<region>.neon.tech/neondb?sslmode=require
# app/config.py auto-rewrites postgresql:// to postgresql+psycopg:// for psycopg3.
# Defense-in-depth: a SQLite URL is rejected at startup outside the
# `development` and `test` environments — see app/config.py.
DATABASE_URL=sqlite:///./dev.db

# Public base URL the app serves itself at. Used for self-referential
# links (email magic links, redirects). For PR previews, leave empty
# and the request handler falls back to the X-Forwarded-Host header
# (see docs/PATTERN-LIBRARY.md pattern #4).
APP_URL=http://localhost:8080

# Switches startup-time validation. Allowed values:
#   development  — local dev, SQLite default permitted
#   test         — pytest, SQLite default permitted
#   preview      — per-PR Neon branch, requires DATABASE_URL set
#   production   — main Neon branch, requires DATABASE_URL set
ENVIRONMENT=development
